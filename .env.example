APP_ENV=development
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

POSTGRES_DB=multi_media
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/multi_media
INTERNAL_API_KEY=dev-internal-key
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

MODEL_PROVIDER=litellm
MODEL_NAME=openai/gpt-4o-mini
MODEL_TIMEOUT_SECONDS=20
MODEL_MAX_RETRIES=1
MODEL_TEMPERATURE=0.4
GENERATION_AUTO_START_ENABLED=false
GENERATION_BACKGROUND_WORKERS=2
TREND_RSSHUB_BASE_URL=https://rsshub.app
TREND_RSSHUB_PLATFORM_ROUTES={"bilibili":"/bilibili/popular/all"}
TREND_RSSHUB_ITEM_LIMIT=5

# Optional provider secret for real model execution.
OPENAI_API_KEY=your-actual-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
